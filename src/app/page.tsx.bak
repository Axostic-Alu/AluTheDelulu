            top: cursorPos.y - 250,
            background: "radial-gradient(circle, rgba(108, 92, 231, 0.12) 0%, rgba(168, 85, 247, 0.06) 40%, transparent 70%)",
          }}
        />
        {/* Middle glow - tighter */}
        <div
          className="absolute h-[200px] w-[200px] rounded-full blur-[60px]"
          style={{
            left: cursorPos.x - 100,
            top: cursorPos.y - 100,
            background: "radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, rgba(108, 92, 231, 0.08) 50%, transparent 80%)",
          }}
        />
        {/* Core dot */}
        <div
          className="absolute h-[8px] w-[8px] rounded-full"
          style={{
            left: cursorPos.x - 4,
            top: cursorPos.y - 4,
            background: "#a855f7",
            boxShadow: "0 0 20px rgba(168, 85, 247, 0.5), 0 0 60px rgba(108, 92, 231, 0.3)",
          }}
        />
      </div>

      {/* ════════════════════════════════════════════════════════ */}
      {/*  HERO
      {/* ════════════════════════════════════════════════════════ */}
      <Section id="hero" className="flex min-h-screen items-center pt-20 overflow-hidden">
        {/* Decorative parallax orbs */}
        <motion.div
          className="pointer-events-none absolute -top-40 -right-40 h-[500px] w-[500px] rounded-full bg-[var(--color-accent)]/5 blur-[150px]"
          style={{ y: heroParallax }}
        />
        <motion.div
          className="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-[var(--color-accent-2)]/5 blur-[120px]"
          style={{ y: useTransform(useScroll().scrollY, [0, 1000], [0, 50]) }}
        />

        <div className="mx-auto max-w-7xl px-6">
          <motion.div
            className="max-w-3xl"
